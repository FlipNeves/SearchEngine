@page "/"
@inject ISearchApi Api

<PageTitle>SearchEngine</PageTitle>

<div class="search-page">
    <h1 class="logo">SearchEngine</h1>

    <SearchBar OnSearch="HandleSearch" />

    @if (loading)
    {
        <p aria-busy="true">Buscando…</p>
    }
    else if (response is not null)
    {
        <DidYouMeanBanner Suggestion="response.DidYouMean" OnSearchOriginal="HandleSearchOriginal" />
        <ResultsList Hits="response.Results" />
    }
</div>

@code {
    SearchResponseDto? response;
    bool loading;

    Task HandleSearch(string query) => RunSearch(query, correct: true);

    Task HandleSearchOriginal(string query) => RunSearch(query, correct: false);

    async Task RunSearch(string query, bool correct)
    {
        if (string.IsNullOrWhiteSpace(query)) return;
        loading = true;
        StateHasChanged();
        try
        {
            response = await Api.SearchAsync(query, 20, correct, default);
        }
        finally
        {
            loading = false;
        }
    }
}
