@if (Suggestion is not null)
{
    <div class="did-you-mean">
        Mostrando resultados para <strong>@Suggestion.Corrected</strong>. Buscar em vez disso por
        <a href="#" @onclick="HandleClick" @onclick:preventDefault>@Suggestion.Original</a>?
    </div>
}

@code {
    [Parameter] public DidYouMean? Suggestion { get; set; }
    [Parameter] public EventCallback<string> OnSearchOriginal { get; set; }

    Task HandleClick() => OnSearchOriginal.InvokeAsync(Suggestion!.Original);
}
